<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Gemeinsames Basis-Theme aller AppSonar-Apps. Die Farben kommen aus
         @color/primary usw. — jede App liefert dafür ihre eigenen Werte
         (values/ und values-night/) und überstimmt damit die Defaults. -->
    <style name="Theme.AppSonar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <!-- Ohne explizite Farbe bliebe die Statusleiste auf dem lila
             Material-Default (#3700B3). Sie folgt der Toolbar — hell wie
             dunkel, da toolbar_bg per values-night überschrieben wird. -->
        <item name="android:statusBarColor">@color/toolbar_bg</item>
    </style>

    <!-- Gemeinsamer Toolbar-Stil. Kodiert die Dark-Mode-Erkenntnisse aus
         HomeSonar 1.3/1.4: feste Toolbar-Farbe statt ?attr/colorPrimary
         (im Dark-Mode per values-night dunkler). Titel und Icons brauchen
         das dunkle ActionBar-Overlay (weiß auf farbiger Leiste); das
         Dreipunkt-Menü darf dieses Overlay aber NICHT erben, sonst steht
         im Light Mode weißer Text auf hellem Popup. Deshalb ein eigenes
         popupTheme, das dem Tag/Nacht-Modus folgt — ein festes Light- oder
         Dark-Overlay wäre im jeweils anderen Modus unlesbar. -->
    <style name="Widget.AppSonar.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/toolbar_bg</item>
        <item name="materialThemeOverlay">@style/ThemeOverlay.AppCompat.Dark.ActionBar</item>
        <item name="popupTheme">@style/ThemeOverlay.AppCompat.DayNight</item>
    </style>
</resources>
